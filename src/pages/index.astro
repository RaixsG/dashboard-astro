---
import AppDashboard from '../components/AppDashboard.vue';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard - INABIF en Acción</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
  <style>
    body { background: #f4f6f9; font-family: 'Segoe UI', Tahoma, sans-serif; }
    .navbar { background: linear-gradient(135deg, #0d6efd, #0b5ed7); }
    .navbar-brand { font-weight: 700; font-size: 1.3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
    @media (max-width: 576px) { .navbar-brand { font-size: 1rem; } }
  </style>
</head>
<body>
  <nav class="navbar navbar-dark shadow-sm mb-4">
    <div class="container-fluid px-4">
      <span class="navbar-brand">INABIF en Acción · Panel de Monitoreo de Riesgos Sociales</span>
    </div>
  </nav>

  <AppDashboard client:only="vue" />

  <script src="/data.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" is:inline></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
  <script src="https://code.jquery.com/jquery-3.7.0.min.js" is:inline></script>
  <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js" is:inline></script>
  <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js" is:inline></script>
</body>
</html>